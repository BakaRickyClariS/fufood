# 後端 API base URL（只含 host，不含路徑）
# Dev: http://localhost:3000 | Prod: https://api.fufood.jocelynh.me
VITE_API_BASE_URL=

# Cloudinary（unsigned upload）
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=

# 開發環境使用 Mock API（true/false）
VITE_USE_MOCK_API=true

# LINE 登入模式：popup | redirect | auto
# popup: 使用彈出視窗（適合桌面瀏覽器）
# redirect: 使用頁面跳轉（適合 PWA standalone）
# auto: 自動偵測（PWA 用 redirect，其他用 popup）
VITE_LINE_LOGIN_MODE=auto

# Firebase Config (Push Notification)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
